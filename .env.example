# API base URL the frontend calls.
#
# DEV (recommended): use the relative path "/api". Vite proxies it to the
# backend (configured in vite.config.ts), which avoids the backend's missing
# CORS headers.
VITE_API_BASE_URL=/api

VITE_BACKEND_ORIGIN=https://localhost:7271

# PRODUCTION: point this at the backend's /api directly, e.g.
#   VITE_API_BASE_URL=http://uni-edu-load-balancer-664470090.ap-southeast-1.elb.amazonaws.com/api
# NOTE: this only works once the backend enables CORS for your frontend origin,
# or the frontend is served behind the same origin as the API.

# Optional: override the backend the Vite dev proxy targets.
# VITE_BACKEND_ORIGIN=http://uni-edu-load-balancer-664470090.ap-southeast-1.elb.amazonaws.com
